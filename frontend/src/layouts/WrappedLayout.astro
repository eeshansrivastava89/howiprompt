---
import PostHog from '../components/PostHog.astro';

interface Props {
  title?: string;
}

const { title = 'How I Prompt' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
    <script is:inline>if(location.protocol === 'http:' && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') location.replace('https:' + location.href.substring(location.protocol.length));</script>
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content="Your AI prompting patterns, wrapped — personas, trends, and metrics from your coding conversations.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://github.com/user-attachments/assets/50331aa6-0d11-416e-8101-ff3fa5a5e01f">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content="Your AI prompting patterns, wrapped — personas, trends, and metrics from your coding conversations.">
    <meta name="twitter:image" content="https://github.com/user-attachments/assets/50331aa6-0d11-416e-8101-ff3fa5a5e01f">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,600&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
    <style is:global>
      @import '../styles/global.css';
      @import '../styles/shared-ui.css';
      @import '../styles/wrapped.css';
      @import '../styles/methodology.css';
    </style>

    <PostHog />
</head>
<body class="bg-bg text-text font-sans antialiased transition-colors duration-300">
    <slot />
</body>
</html>
