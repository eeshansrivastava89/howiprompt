---
import PostHog from '../components/PostHog.astro';

interface Props {
  title?: string;
}

const { title = 'How I Prompt: Dashboard' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Prevent flash of light theme -->
    <script is:inline>
      (function(){var s=localStorage.getItem('hip-theme');if(s==='dark'||(!s&&matchMedia('(prefers-color-scheme:dark)').matches))document.documentElement.classList.add('dark')})();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content="Local-first analytics for your AI coding conversations — prompts, personas, trends, and a personal wrapped view.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://github.com/user-attachments/assets/7d9ecf37-74f3-4bab-9920-52bc13f3371a">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content="Local-first analytics for your AI coding conversations — prompts, personas, trends, and a personal wrapped view.">
    <meta name="twitter:image" content="https://github.com/user-attachments/assets/7d9ecf37-74f3-4bab-9920-52bc13f3371a">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,600&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
    <script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts@4/dist/apexcharts.min.js"></script>

    <style is:global>
      @import '../styles/global.css';
      @import '../styles/shared-ui.css';
      @import '../styles/dashboard.css';
      @import '../styles/linguistics.css';
      @import '../styles/methodology.css';
    </style>

    <PostHog />
</head>
<body>
    <slot />
</body>
</html>
