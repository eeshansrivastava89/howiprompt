---
const repoUrl = 'https://github.com/eeshansrivastava89/howiprompt';
const pagesGuideUrl = 'https://docs.github.com/en/pages/quickstart';
const runCommand = 'npx @eeshans/howiprompt';
const cloneCommand = 'git clone https://github.com/eeshansrivastava89/howiprompt.git';
const devCliCommand = 'cd howiprompt && npm install && npm run dev:cli';
const buildDemoCommand = 'cd howiprompt/frontend && DEMO_DEPLOY=true npm run build';
---

<div class="modal-overlay" id="createModal" role="dialog" aria-modal="true" aria-labelledby="createTitle">
  <div class="create-modal">
    <div class="create-header">
      <div class="create-header-left">
        <div class="create-logo">&lt;/&gt;</div>
        <div>
          <div class="create-header-title" id="createTitle">Create Your Own</div>
          <div class="create-header-sub">Run privately on your machine or publish your own hosted snapshot.</div>
        </div>
      </div>
      <button class="modal-close" onclick="closeCreateModal()" aria-label="Close create your own modal">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="create-body">
      <section class="create-card">
        <div class="create-section-head">
          <p class="create-eyebrow">1 command</p>
          <h3 class="create-rule">Run Fully Local</h3>
        </div>
        <p class="create-card-copy">Private, local-first analytics in one command. No hosting, no setup, no extra steps.</p>
        <div class="command-strip" role="group" aria-label="Run command">
          <div class="command-line-wrap">
            <div class="command-line">
              <span class="command-prompt">$</span>
              <code>{runCommand}</code>
            </div>
          </div>
          <div class="command-actions">
            <button class="create-copy-btn" type="button" data-copy-text={runCommand} aria-label="Copy npx command">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span class="create-copy-label">Copy</span>
            </button>
            <a class="create-source-link" href={repoUrl} target="_blank" rel="noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 008 10.94c.58.1.79-.25.79-.56l-.02-2.15c-3.25.71-3.94-1.56-3.94-1.56-.53-1.35-1.3-1.71-1.3-1.71-1.07-.73.08-.71.08-.71 1.18.08 1.8 1.21 1.8 1.21 1.05 1.8 2.76 1.28 3.43.98.1-.76.41-1.28.74-1.58-2.59-.29-5.31-1.29-5.31-5.75 0-1.27.45-2.31 1.2-3.12-.12-.29-.52-1.46.12-3.04 0 0 .98-.31 3.2 1.19a11.1 11.1 0 015.82 0c2.21-1.5 3.19-1.19 3.19-1.19.64 1.58.24 2.75.12 3.04.75.81 1.2 1.85 1.2 3.12 0 4.47-2.73 5.46-5.33 5.74.42.36.79 1.08.79 2.17l-.01 3.22c0 .31.21.67.8.56A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"></path></svg>
              <span>Source</span>
            </a>
          </div>
        </div>
      </section>

      <section class="create-card create-card-muted">
        <div class="create-section-head">
          <p class="create-eyebrow">3 steps</p>
          <h3 class="create-rule">Self-Host On GitHub Pages</h3>
        </div>
        <p class="create-card-copy">Publish your own persona and stats as a shareable static site in three short steps.</p>

        <div class="create-steps" aria-label="Self-host on GitHub Pages">
          <div class="create-step">
            <div class="create-step-head"><span class="create-step-num">1</span><span class="create-step-title">Clone the repo</span></div>
            <div class="create-step-command">
              <code>{cloneCommand}</code>
              <button class="create-copy-btn create-copy-btn-sm" type="button" data-copy-text={cloneCommand} aria-label="Copy clone command">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <span class="create-copy-label">Copy</span>
              </button>
            </div>
          </div>

          <div class="create-step">
            <div class="create-step-head"><span class="create-step-num">2</span><span class="create-step-title">Launch the local app</span></div>
            <div class="create-step-command">
              <code>{devCliCommand}</code>
              <button class="create-copy-btn create-copy-btn-sm" type="button" data-copy-text={devCliCommand} aria-label="Copy dev CLI command">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <span class="create-copy-label">Copy</span>
              </button>
            </div>
          </div>

          <div class="create-step">
            <div class="create-step-head"><span class="create-step-num">3</span><span class="create-step-title">Build the hosted snapshot</span></div>
            <div class="create-step-command">
              <code>{buildDemoCommand}</code>
              <button class="create-copy-btn create-copy-btn-sm" type="button" data-copy-text={buildDemoCommand} aria-label="Copy demo build command">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <span class="create-copy-label">Copy</span>
              </button>
            </div>
          </div>
        </div>

        <p class="create-hosted-note">Then commit and push `docs/`, and enable GitHub Pages from `main` / `docs`. <a href={pagesGuideUrl} target="_blank" rel="noreferrer">Setup guide</a></p>
      </section>
    </div>

    <div class="create-bottom">
      <span class="create-bottom-note">One command for local-only use. One optional path for a public hosted snapshot.</span>
    </div>
  </div>
</div>
