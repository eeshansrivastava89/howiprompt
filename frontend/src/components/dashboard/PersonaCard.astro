---
// Persona card: name, description, traits, quadrant scores, signature
---
<div class="card card-wide animate delay-8">
    <div class="card-label">Your AI Persona</div>
    <div class="persona-card" style="margin-top: 12px;">
        <div class="persona-main">
            <div class="persona-name" id="personaName">--</div>
            <div class="persona-desc" id="personaDescription">Loading persona data...</div>
            <div class="persona-traits" id="personaTraits"></div>
        </div>
        <div class="persona-stats">
            <div class="quadrant-scores">
                <div class="quadrant-item">
                    <div class="quadrant-value" id="engagementScore">--</div>
                    <div class="quadrant-label">Engagement</div>
                    <span class="quadrant-tag low" id="engagementTag">--</span>
                </div>
                <div class="quadrant-item">
                    <div class="quadrant-value" id="politenessScore">--</div>
                    <div class="quadrant-label">Politeness</div>
                    <span class="quadrant-tag low" id="politenessTag">--</span>
                </div>
            </div>
            <div class="signature">
                <div class="signature-quote">"You're absolutely right."</div>
                <div class="signature-count" id="youreRightCount">×--</div>
                <div class="signature-label" id="youreRightLabel">--× per conversation</div>
            </div>
        </div>
    </div>
</div>
