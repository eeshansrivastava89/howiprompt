---
// Conversation depth: 3 progress bars + longest session
---
<div class="card card-wide animate delay-6">
    <div class="card-label">Conversation Depth</div>
    <div style="margin-top: 12px;">
        <div class="progress-item">
            <div class="progress-header">
                <span class="progress-label">Quick Asks (1-3 turns)</span>
                <span class="progress-value" id="quickAsksValue">--</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="quickAsksFill" style="width: 0%"></div>
            </div>
        </div>
        <div class="progress-item">
            <div class="progress-header">
                <span class="progress-label">Working Sessions (4-10)</span>
                <span class="progress-value" id="workingSessionsValue">--</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="workingSessionsFill" style="width: 0%"></div>
            </div>
        </div>
        <div class="progress-item">
            <div class="progress-header">
                <span class="progress-label">Deep Dives (11+)</span>
                <span class="progress-value" id="deepDivesValue">--</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="deepDivesFill" style="width: 0%"></div>
            </div>
        </div>
    </div>
    <div class="peak-stats" style="margin-top: 16px;">
        <div class="peak-stat">
            <span class="peak-stat-label">Longest Session</span>
            <span class="peak-stat-value" id="longestSessionValue">-- turns</span>
        </div>
    </div>
</div>
