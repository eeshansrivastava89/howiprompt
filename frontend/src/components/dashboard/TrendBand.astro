---
// Trend band: 4 ECharts trend cards (question rate, command rate, politeness, backtrack)
---
<div class="trend-grid animate delay-4">
    <div class="card trend-chart-card">
        <div class="trend-chart-header">
            <span class="card-label">Question Rate</span>
            <span class="trend-badge" id="badgeQuestionRate"></span>
        </div>
        <div class="trend-chart" id="chartQuestionRate"></div>
    </div>
    <div class="card trend-chart-card">
        <div class="trend-chart-header">
            <span class="card-label">Command Rate</span>
            <span class="trend-badge" id="badgeCommandRate"></span>
        </div>
        <div class="trend-chart" id="chartCommandRate"></div>
    </div>
    <div class="card trend-chart-card">
        <div class="trend-chart-header">
            <span class="card-label">Politeness</span>
            <span class="trend-badge" id="badgePoliteness"></span>
        </div>
        <div class="trend-chart" id="chartPoliteness"></div>
    </div>
    <div class="card trend-chart-card">
        <div class="trend-chart-header">
            <span class="card-label">Backtrack</span>
            <span class="trend-badge" id="badgeBacktrack"></span>
        </div>
        <div class="trend-chart" id="chartBacktrack"></div>
    </div>
</div>
