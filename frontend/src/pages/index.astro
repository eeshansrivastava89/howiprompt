---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import Header from '../components/dashboard/Header.astro';
import HeroStats from '../components/dashboard/HeroStats.astro';
import ActivityHeatmap from '../components/dashboard/ActivityHeatmap.astro';
import ConversationDepth from '../components/dashboard/ConversationDepth.astro';
import PromptStyle from '../components/dashboard/PromptStyle.astro';
import PersonaCard from '../components/dashboard/PersonaCard.astro';
import MethodologyModal from '../components/dashboard/MethodologyModal.astro';
import Footer from '../components/dashboard/Footer.astro';
---
<DashboardLayout title="How I Prompt: Dashboard">
    <div class="container">
        <Header />
        <HeroStats />

        <!-- Main Grid -->
        <div class="grid">
            <ActivityHeatmap />
            <ConversationDepth />
            <PromptStyle />
            <PersonaCard />
        </div>

        <Footer />
    </div>

    <MethodologyModal />

    <script src="../scripts/dashboard.js"></script>
</DashboardLayout>
